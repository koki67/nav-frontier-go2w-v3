<?xml version="1.0" encoding="UTF-8" ?>
<!--
  CycloneDDS profile for the Go2W frontier exploration stack.

  The default network interface is `eth0` (typical robot setup).  For desktop
  development you can override at runtime by exporting
  CYCLONEDDS_NETWORK_INTERFACE=wlan0 (or whichever interface the host uses)
  before starting the container, or by editing this file.
-->
<CycloneDDS>
    <Domain Id="any">
        <General>
            <Interfaces>
                <NetworkInterface name="eth0" priority="default" multicast="default" />
            </Interfaces>
        </General>
    </Domain>
</CycloneDDS>
